{
  "expo": {
    "name": "VoiceLens",
    "slug": "voicelens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "sdkVersion": "52.0.0",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "VoiceLens needs camera access to read text from documents.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to record audio for speech recognition.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.allysonai.voicelens"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.allysonai.voicelens"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "VoiceLens needs camera access to read text from documents.",
          "enableFrameProcessors": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone."
        }
      ],
      [
        "expo-file-system",
        {
          "filePermission": "This app needs access to files on your device."
        }
      ],
      "expo-dev-client",
      "expo-asset",
      "expo-build-properties"
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "aae2f4c4-9eb0-4120-95f9-b0469a6e4363"
      }
    },
    "owner": "0masn"
  }
}